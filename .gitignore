# 但忽略可能包含敏感信息的临时文件
data/**/*.tmp
data/**/*.bak
data/**/*.old

# 生成的 HTML 报告（构建产物，不提交）
reports/daily/*.html
reports/weekly/*.html
reports/monthly/*.html
reports/index.html

# 保留目录结构
!reports/.gitkeep
!reports/daily/.gitkeep
!reports/weekly/.gitkeep
!reports/monthly/.gitkeep

# 环境变量（敏感）
.env
.env.local
.env.*.local

# AI 分析结果
.processor_state.json
.prompt_*.txt
.result_*.json

# 日志
*.log
/var/log/github-monitor.log

# API 队列
.api-queue/
.api-results/

# 临时文件
*.tmp
*.bak
*.old

# 旧脚本（临时保留）
.old_scripts/

# 依赖
node_modules/

# 测试
coverage/
.nyc_output/

package-lock.json

# IDE 配置（可选）
.vscode/
.idea/

# Git 工作树
.worktrees/

